{
  "info": {
    "name": "AIVIZ 2.0 — Auth (Day 2)",
    "_postman_id": "aiviz-auth-day2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Day 2 auth endpoints: signup, login, refresh, me, google."
  },
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/auth/signup",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"a@b.com\",\n  \"password\": \"Pa55word!\",\n  \"role\": \"student\",\n  \"phone\": \"+919876543210\",\n  \"first_name\": \"Asha\",\n  \"last_name\": \"Rao\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j.tokens) {",
              "  pm.environment.set('access', j.tokens.access);",
              "  pm.environment.set('refresh', j.tokens.refresh);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"a@b.com\",\n  \"password\": \"Pa55word!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j.tokens) {",
              "  pm.environment.set('access', j.tokens.access);",
              "  pm.environment.set('refresh', j.tokens.refresh);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Refresh",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/auth/refresh",
        "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j.access)  pm.environment.set('access', j.access);",
              "if (j.refresh) pm.environment.set('refresh', j.refresh);"
            ]
          }
        }
      ]
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
        "url": "{{base_url}}/api/v1/auth/me"
      }
    },
    {
      "name": "Google (Continue with Google)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/auth/google",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id_token\": \"<paste a real Google ID token from the Expo app>\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j.tokens) {",
              "  pm.environment.set('access', j.tokens.access);",
              "  pm.environment.set('refresh', j.tokens.refresh);",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
