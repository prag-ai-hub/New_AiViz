# ───────────────────────────────────────────────────────────
# AIVIZ 2.0 — monorepo .gitignore
#   aiviz-app/      Expo / React Native
#   aiviz-backend/  Django + DRF + Celery + Channels
# Patterns without a leading slash apply at any depth.
# ───────────────────────────────────────────────────────────

# ── Secrets / environment ──
.env
.env.*
!.env.example

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*~

# ── Logs ──
*.log
logs/

# ═══════════════════════════════════════════════════════════
# JavaScript / Expo / React Native  (aiviz-app)
# ═══════════════════════════════════════════════════════════
node_modules/
.expo/
dist/
web-build/
*.tsbuildinfo
coverage/

# Native build output
ios/
android/

# @generated expo-cli sync-2b81b286409207a5da26e14c78851eb30d8ccbdb
# The following patterns were generated by expo-cli
expo-env.d.ts
# @end expo-cli

# Metro / bundler caches
.metro-health-check*
.metro-cache/

# ═══════════════════════════════════════════════════════════
# Python / Django / Celery  (aiviz-backend)
# ═══════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/

# Virtual environments (backend + workspace-root .venv)
.venv/
venv/
env/

# Django
db.sqlite3
db.sqlite3-journal
staticfiles/
media/
local_settings.py

# Celery runtime artifacts
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid
*.pid

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ── Local data / dumps ──
dump.rdb
*.dump
